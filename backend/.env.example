# SplitSure backend development settings
DATABASE_URL=postgresql+asyncpg://splitsure:splitsure_dev@localhost:5432/splitsure
SECRET_KEY=dev-secret-key-change-in-production-use-32-chars-min

# Local storage in dev
USE_LOCAL_STORAGE=true
LOCAL_UPLOAD_DIR=uploads
LOCAL_BASE_URL=http://localhost:8000

# Dev OTP mode
USE_DEV_OTP=true

# Optional cloud config for non-dev environments
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=splitsure-proofs
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# CORS
ALLOWED_ORIGINS=["http://localhost:8081","http://localhost:19006","http://10.0.2.2:8000"]
