{
  "expo": {
    "name": "SplitSure",
    "slug": "splitsure",
    "version": "1.1",
    "scheme": "splitsure",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "plugins": ["expo-router"],
    "android": {
      "package": "com.splitsure.app",
      "usesCleartextTraffic": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "splitsure",
              "host": "*"
            }
          ],
          "category": ["DEFAULT", "BROWSABLE"]
        }
      ]
    },
    "ios": {
      "bundleIdentifier": "com.splitsure.app"
    }
  }
}
